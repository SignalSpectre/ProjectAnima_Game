{
    "version": 8,
    "configurePresets": [
        {
            "name": "Release_PSP",
            "displayName": "Release_PSP",
            "binaryDir": "${sourceDir}/build/${presetName}",
            "cacheVariables": {
                "CMAKE_BUILD_TYPE": "Release",
                "CMAKE_TOOLCHAIN_FILE": "$env{PSPDEV}/psp/share/pspdev.cmake",
                "CMAKE_INSTALL_PREFIX": "${sourceDir}/out/install/${presetName}"
            }
        },
        {
            "name": "Debug_PSP",
            "displayName": "Debug_PSP",
            "inherits": [
                "Release_PSP"
            ],
            "cacheVariables": {
                "CMAKE_BUILD_TYPE": "Debug",
                "CMAKE_TOOLCHAIN_FILE": "$env{PSPDEV}/psp/share/pspdev.cmake",
                "CMAKE_INSTALL_PREFIX": "${sourceDir}/out/install/${presetName}",
                "BUILD_PRX": "ON"
            }
        }
    ],
    "buildPresets": [
        {
            "name": "BuildDebug_PSP",
            "configurePreset": "Debug_PSP",
            "jobs": 8
        },
        {
            "name": "BuildRelease_PSP",
            "configurePreset": "Release_PSP",
            "jobs": 8
        }
    ]
}