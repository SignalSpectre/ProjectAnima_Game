{
    "version": 8,
    "configurePresets": [
        {
            "name": "PSPRelease",
            "displayName": "PSPRelease",
            "binaryDir": "${sourceDir}/build/${presetName}",
            "cacheVariables": {
                "CMAKE_BUILD_TYPE": "Release",
                "CMAKE_TOOLCHAIN_FILE": "$env{PSPDEV}/psp/share/pspdev.cmake",
                "CMAKE_INSTALL_PREFIX": "${sourceDir}/out/install/${presetName}"
            }
        },
        {
            "name": "PSPDebug",
            "displayName": "PSPDebug",
            "inherits": [
                "PSPRelease"
            ],
            "cacheVariables": {
                "CMAKE_BUILD_TYPE": "Debug",
                "CMAKE_TOOLCHAIN_FILE": "$env{PSPDEV}/psp/share/pspdev.cmake",
                "CMAKE_INSTALL_PREFIX": "${sourceDir}/out/install/${presetName}",
                "BUILD_PRX": "ON"
            }
        }
    ],
    "buildPresets": [
        {
            "name": "BuildDebug",
            "configurePreset": "PSPDebug",
            "jobs": 0
        },
        {
            "name": "BuildRelease",
            "configurePreset": "PSPRelease",
            "jobs": 0
        }
    ]
}